# ── htcondor_monitor configuration ──────────────────────────────────────────
# Copy this to .env in the project root and fill in your values.
# All variables are prefixed HTCONDOR_ (handled by pydantic-settings).

# ── OpenSearch connection ────────────────────────────────────────────────────
HTCONDOR_OPENSEARCH_HOST=https://my-opensearch-cluster:9200
HTCONDOR_OPENSEARCH_INDEX_PREFIX=htcondor-jobs
HTCONDOR_OPENSEARCH_USERNAME=monitor_user
HTCONDOR_OPENSEARCH_PASSWORD=changeme
# HTCONDOR_OPENSEARCH_CA_CERT=/etc/ssl/certs/opensearch-ca.pem

# ── Anthropic LLM ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
HTCONDOR_ANTHROPIC_MODEL=claude-sonnet-4-20250514
HTCONDOR_AGENT_MAX_STEPS=20

# ── ClassAd field names (override if your ingest renames fields) ─────────────
# HTCONDOR_FIELD_USER=Owner
# HTCONDOR_FIELD_MEMORY_USAGE=ResidentSetSize
# HTCONDOR_FIELD_WALL_TIME=RemoteWallClockTime

# ── Monitoring thresholds ───────────────────────────────────────────────────
HTCONDOR_CPU_EFFICIENCY_WARN_PCT=30.0
HTCONDOR_MEMORY_OVERREQUEST_RATIO=2.0
HTCONDOR_NODE_FAILURE_RATE_PCT=15.0
HTCONDOR_GPU_IDLE_THRESHOLD_PCT=10.0

# ── State and reports ───────────────────────────────────────────────────────
HTCONDOR_STATE_DIR=/var/lib/htcondor_monitor/state
HTCONDOR_REPORT_OUTPUT_DIR=/var/lib/htcondor_monitor/reports
HTCONDOR_STATE_HISTORY_DEPTH=5

# ── Email reporting (leave REPORT_EMAIL_TO empty to disable) ────────────────
HTCONDOR_REPORT_EMAIL_TO=admin@example.com,ops@example.com
HTCONDOR_REPORT_EMAIL_FROM=htcondor-monitor@example.com
HTCONDOR_SMTP_HOST=mail.example.com
HTCONDOR_SMTP_PORT=25
